// INSTRUCCIONES DE DESPLIEGUE:
// 1. Instalá Firebase CLI: npm install -g firebase-tools
// 2. Iniciá sesión: firebase login
// 3. Iniciá el proyecto: firebase init firestore
// 4. Ejecutá: firebase deploy --only firestore:rules
// Sin este despliegue las reglas no tienen efecto en producción.

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Productos: lectura pública, escritura solo admin autenticado
    match /products/{docId} {
      allow read: if true;
      allow write, delete: if request.auth != null;
    }

    // Settings (Ajustes): lectura pública, escritura solo admin autenticado
    match /settings/{docId} {
      allow read: if true;
      allow write, delete: if request.auth != null;
    }

    // Todo lo demás: denegado
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
